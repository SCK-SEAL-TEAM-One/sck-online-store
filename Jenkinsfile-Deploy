pipeline {
    agent any

  
    options {
        disableConcurrentBuilds()
    }
  

    environment {
        DOCKER_REGISTRY = 'siamchamnankit'
        DOCKER_CREDENTIALS_ID = 'dockerhub-credentials'
        KUBECONFIG_CREDENTIAL_ID = 'kubeconfig.yaml'
        K8S_NAMESPACE = 'public'
    }

    parameters {
        string(
            name: 'IMAGE_TAG',
            defaultValue: '',
            description: 'Docker image tag to deploy (required from upstream build)'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['development', 'staging', 'production'],
            description: 'Select target environment'
        )
        booleanParam(
            name: 'DEPLOY_ALL',
            defaultValue: true,
            description: 'Deploy all services'
        )
        booleanParam(
            name: 'DEPLOY_STORE_SERVICE',
            defaultValue: false,
            description: 'Deploy store-service only'
        )
        booleanParam(
            name: 'DEPLOY_POINT_SERVICE',
            defaultValue: false,
            description: 'Deploy point-service only'
        )
        booleanParam(
            name: 'DEPLOY_STORE_WEB',
            defaultValue: false,
            description: 'Deploy store-web only'
        )
    }

    stages {
        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.IMAGE_TAG) {
                        error("IMAGE_TAG parameter is required. This pipeline should be triggered from the main build pipeline.")
                    }
                    env.DEPLOY_TAG = params.IMAGE_TAG
                    echo "=== Deploying images with tag: ${env.DEPLOY_TAG} ==="
                    echo "=== Target environment: ${params.ENVIRONMENT} ==="
                }
            }
        }

        stage('Validate kubectl') {
            steps {
                script {
                    echo "=== Validating kubectl connection ==="
                    withKubeConfig([credentialsId: env.KUBECONFIG_CREDENTIAL_ID]) {
                        sh '''
                            kubectl version --client
                            kubectl cluster-info
                            kubectl get nodes
                        '''
                    }
                }
            }
        }

        stage('Update Image Tags in Manifests') {
            steps {
                script {
                    echo "=== Updating Kubernetes manifests with image tag: ${env.DEPLOY_TAG} ==="
                    sh '''
                        # Create backup and update image tags in deployment files
                        sed -i.bak "s|image: ${DOCKER_REGISTRY}/store-service.*|image: ${DOCKER_REGISTRY}/store-service:${DEPLOY_TAG}|g" deploy/store-service/service.yml
                        sed -i.bak "s|image: ${DOCKER_REGISTRY}/point-service.*|image: ${DOCKER_REGISTRY}/point-service:${DEPLOY_TAG}|g" deploy/point-service/service.yml
                        sed -i.bak "s|image: ${DOCKER_REGISTRY}/store-web.*|image: ${DOCKER_REGISTRY}/store-web:${DEPLOY_TAG}|g" deploy/store-web/service.yml
                        sed -i.bak "s|image: ${DOCKER_REGISTRY}/store-database.*|image: ${DOCKER_REGISTRY}/store-database:${DEPLOY_TAG}|g" deploy/store-database/service.yml
                        
                        # Show changes
                        echo "Updated deployment files:"
                        grep "image:" deploy/*/service.yml || true
                    '''
                }
            }
        }

        stage('Deploy Services') {
            steps {
                script {
                    withKubeConfig([credentialsId: env.KUBECONFIG_CREDENTIAL_ID, namespace: env.K8S_NAMESPACE]) {
                        
                        if (params.DEPLOY_ALL || params.DEPLOY_POINT_SERVICE) {
                            echo "=== Deploying point-service ==="
                            sh '''
                                kubectl apply -f deploy/point-service/service.yml
                            '''
                        }

                        if (params.DEPLOY_ALL || params.DEPLOY_STORE_SERVICE) {
                            echo "=== Deploying store-service ==="
                            sh '''
                                kubectl apply -f deploy/store-service/service.yml
                            '''
                        }

                        if (params.DEPLOY_ALL || params.DEPLOY_STORE_WEB) {
                            echo "=== Deploying store-web ==="
                            sh '''
                                kubectl apply -f deploy/store-web/service.yml
                            '''
                        }

                    }
                }
            }
        }

        stage('Deploy Ingress') {
            when {
                expression { params.DEPLOY_ALL == true }
            }
            steps {
                script {
                    echo "=== Deploying Ingress and Middleware ==="
                    withKubeConfig([credentialsId: env.KUBECONFIG_CREDENTIAL_ID, namespace: env.K8S_NAMESPACE]) {
                        sh '''
                            kubectl apply -f deploy/ingress.yml
                        '''
                    }
                }
            }
        }

        stage('Verify Deployments') {
            steps {
                script {
                    echo "=== Verifying deployments ==="
                    withKubeConfig([credentialsId: env.KUBECONFIG_CREDENTIAL_ID, namespace: env.K8S_NAMESPACE]) {
                        sh '''
                            echo "Checking deployments status..."
                            kubectl get deployments
                            
                            echo "\nChecking services..."
                            kubectl get services
                            
                            echo "\nChecking ingress..."
                            kubectl get ingress
                            
                            echo "\nChecking pods..."
                            kubectl get pods
                        '''
                        
                        // Wait for rollout to complete
                        timeout(time: 5, unit: 'MINUTES') {
                            if (params.DEPLOY_ALL) {
                                sh 'kubectl rollout status deployment/mysql --timeout=300s' || true
                            }
                            if (params.DEPLOY_ALL || params.DEPLOY_POINT_SERVICE) {
                                sh 'kubectl rollout status deployment/point-service-deployment --timeout=300s'
                            }
                            if (params.DEPLOY_ALL || params.DEPLOY_STORE_SERVICE) {
                                sh 'kubectl rollout status deployment/store-service-deployment --timeout=300s'
                            }
                            if (params.DEPLOY_ALL || params.DEPLOY_STORE_WEB) {
                                sh 'kubectl rollout status deployment/store-web-deployment --timeout=300s'
                            }
                        }
                        
                        echo "=== Deployment verification completed successfully ==="
                    }
                }
            }
        }

        stage('Health Check') {
            when {
                expression { params.DEPLOY_ALL == true }
            }
            steps {
                script {
                    echo "=== Running health checks ==="
                    withKubeConfig([credentialsId: env.KUBECONFIG_CREDENTIAL_ID, namespace: env.K8S_NAMESPACE]) {
                        sh '''
                            # Wait for pods to be ready
                            echo "Waiting for all pods to be ready..."
                            kubectl wait --for=condition=ready pod -l app=mysql --timeout=300s || true
                            kubectl wait --for=condition=ready pod -l app=point-service --timeout=300s || true
                            kubectl wait --for=condition=ready pod -l app=store-service --timeout=300s || true
                            kubectl wait --for=condition=ready pod -l app=store-web --timeout=300s || true
                            
                            # Show final status
                            echo "\n=== Final Pod Status ==="
                            kubectl get pods -o wide
                            
                            echo "\n=== Service Endpoints ==="
                            kubectl get endpoints
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo "=== Deployment Pipeline Completed ==="
                echo "Environment: ${params.ENVIRONMENT}"
                echo "Deployed Image Tag: ${env.DEPLOY_TAG}"
                echo "Build Number: ${BUILD_NUMBER}"
                
                // Restore original deployment files
                sh '''
                    if [ -f deploy/store-service/service.yml.bak ]; then
                        rm -f deploy/*/service.yml.bak
                    fi
                '''
            }
        }
        success {
            script {
                echo "✅ Deployment completed successfully!"
                withKubeConfig([credentialsId: env.KUBECONFIG_CREDENTIAL_ID, namespace: env.K8S_NAMESPACE]) {
                    sh '''
                        echo "\n=== Deployment Summary ==="
                        kubectl get all -o wide
                    '''
                }
            }
        }
        failure {
            script {
                echo "❌ Deployment failed!"
                withKubeConfig([credentialsId: env.KUBECONFIG_CREDENTIAL_ID, namespace: env.K8S_NAMESPACE]) {
                    sh '''
                        echo "\n=== Troubleshooting Information ==="
                        echo "\nPod Status:"
                        kubectl get pods
                        
                        echo "\nRecent Events:"
                        kubectl get events --sort-by='.lastTimestamp' | tail -20
                        
                        echo "\nPod Descriptions:"
                        kubectl describe pods | grep -A 10 "Events:" || true
                    '''
                }
            }
        }
    }
}
