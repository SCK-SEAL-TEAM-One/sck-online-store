          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build Order Body" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">
import groovy.json.JsonBuilder

def cartCount = (vars.get(&quot;cart_product_id_matchNr&quot;) ?: &quot;0&quot;).toInteger()
def cartItems = []
for (int i = 1; i &lt;= cartCount; i++) {
    cartItems.add([
        product_id: (vars.get(&quot;cart_product_id_&quot; + i) ?: &quot;0&quot;).toInteger(),
        quantity: (vars.get(&quot;cart_quantity_&quot; + i) ?: &quot;0&quot;).toInteger()
    ])
}

def userId = ctx.getThreadNum() + 1
def shippingMethodId = new Random().nextInt(3) + 1
def paymentMethodId = new Random().nextInt(2) + 1
def totalPrice = (vars.get(&quot;total_price_thb&quot;) ?: &quot;0&quot;).toDouble()

vars.put(&quot;orderBody&quot;, new JsonBuilder([
    cart: cartItems,
    shipping_method_id: shippingMethodId,
    shipping_address: &quot;123 Load Test Street&quot;,
    shipping_sub_disterict: &quot;Klongtoey&quot;,
    shipping_district: &quot;Klongtoey&quot;,
    shipping_province: &quot;Bangkok&quot;,
    shipping_zip_code: &quot;10110&quot;,
    recipient_first_name: &quot;Load&quot;,
    recipient_last_name: &quot;Test &quot; + userId,
    recipient_phone_number: &quot;0812345678&quot;,
    payment_method_id: paymentMethodId,
    sub_total_price: totalPrice,
    discount_price: 0,
    total_price: totalPrice,
    burn_point: 0
]).toString())
              </stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
