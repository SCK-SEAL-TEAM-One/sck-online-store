      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_MIMIR}" },
          "expr": "sum(orders_created_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
